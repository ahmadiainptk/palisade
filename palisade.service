[Unit]
Description=Palisade DNS-over-HTTPS Tunnel
Documentation=https://github.com/Jigsaw-Code/Intra
After=network-online.target nftables.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/palisade
ExecStop=/bin/kill -TERM $MAINPID
Restart=on-failure
RestartSec=5
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW
NoNewPrivileges=no
TimeoutStopSec=10
KillMode=mixed
KillSignal=SIGTERM

[Install]
WantedBy=multi-user.target
